{
  "name": "qdrant-codebase-mcp",
  "version": "0.1.2",
  "description": "MCP server that indexes your codebase into Qdrant and exposes semantic vector search — enabling AI assistants to find relevant code by meaning, not keyword.",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "qdrant-codebase-mcp": "./dist/mcp-entry.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "qdrant",
    "codebase-indexing",
    "semantic-search",
    "code-search",
    "embeddings",
    "fastembed",
    "ai",
    "llm",
    "copilot",
    "roo-code",
    "vector-search"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/theepicsaxguy/qdrant-codebase-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/theepicsaxguy/qdrant-codebase-mcp/issues"
  },
  "homepage": "https://github.com/theepicsaxguy/qdrant-codebase-mcp#readme",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src tests --max-warnings 0",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run tests/unit",
    "test:python": "python3 -m unittest tests.test_uvx_launcher",
    "test:integration": "vitest run tests/integration",
    "test:all": "vitest run",
    "test:watch": "vitest tests/unit",
    "mcp": "node dist/mcp-entry.js",
    "mcp:dev": "tsx src/mcp-entry.ts",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "audit": "npm audit --audit-level=moderate",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "publish:all": "bash scripts/publish.sh",
    "publish:all:ci": "bash scripts/publish.sh --ci",
    "prepare": "[ -d .git ] && husky || true",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run knip && npm run audit && npm test && npm run build"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --max-warnings 0",
      "prettier --check"
    ],
    "*": [
      "secretlint"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "chokidar": "^5.0.0",
    "fast-glob": "^3.3.3",
    "fastembed": "^2.1.0",
    "fastify": "^5.8.4",
    "js-yaml": "^4.1.1",
    "micromatch": "^4.0.8",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@secretlint/secretlint-rule-preset-recommend": "^11.4.1",
    "@types/js-yaml": "^4.0.9",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "knip": "^6.2.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "secretlint": "^11.4.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "onnxruntime-node": "1.24.3",
    "tar": ">=7.5.13"
  }
}
