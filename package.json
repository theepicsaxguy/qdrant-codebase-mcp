{
  "name": "qdrant-codebase-query",
  "version": "0.1.0",
  "description": "Semantic code search for AI assistants — indexes your codebase into Qdrant and exposes it as an MCP tool via `npx qdrant-codebase-query`",
  "main": "dist/index.js",
  "bin": {
    "qdrant-codebase-query": "./dist/mcp-entry.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "qdrant",
    "semantic-search",
    "code-search",
    "embeddings",
    "fastembed",
    "ai",
    "llm",
    "copilot"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/qdrant-codebase-query.git"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src tests",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:all": "vitest run",
    "test:watch": "vitest tests/unit",
    "mcp": "node dist/mcp-entry.js",
    "mcp:dev": "tsx src/mcp-entry.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "chokidar": "^5.0.0",
    "fast-glob": "^3.3.3",
    "fastembed": "^2.1.0",
    "fastify": "^5.8.4",
    "js-yaml": "^4.1.1",
    "micromatch": "^4.0.8",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^25.5.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "onnxruntime-node": "1.20.1",
    "tar": ">=7.5.13"
  }
}
